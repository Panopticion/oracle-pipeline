VITE_SUPABASE_ANON_KEY=<anon_key>
SUPABASE_SERVICE_ROLE_KEY=<service_role_key>

# OpenRouter — AI document parsing + crosswalk generation
OPENROUTER_API_KEY=<openrouter_api_key>

# PDF extraction backend (auto | pdfjs | pdfparse)
# - auto: try pdfjs-dist first, fallback to pdf-parse
# - pdfjs: force pdfjs-dist only
# - pdfparse: force pdf-parse only
PDF_EXTRACTOR=auto
