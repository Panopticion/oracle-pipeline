{
  "name": "@panopticon/corpus-web",
  "version": "0.1.1",
  "private": true,
  "license": "MIT",
  "description": "Panopticon corpus pipeline web application with compliance document parsing, chunking, watermarking, and cross-framework mapping.",
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src app/server",
    "lint:fix": "eslint src app/server --fix",
    "prettier": "prettier --write \"**/*.{md,markdown,yml,yaml}\"",
    "prettier:check": "prettier --check \"**/*.{md,markdown,yml,yaml}\"",
    "cli": "tsx src/cli.ts",
    "worker": "tsx src/worker.ts",
    "worker:dev": "tsx watch src/worker.ts",
    "test": "vitest run",
    "test:cli": "vitest run src/cli.test.ts",
    "test:validator": "vitest run src/validate.test.ts",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.0",
    "@tanstack/react-router": "^1.114.0",
    "@tanstack/react-start": "^1.114.0",
    "fflate": "^0.8.2",
    "nitro": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.21.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.24.1",
    "vite-tsconfig-paths": "^4.3.0",
    "vite": "^7.0.0",
    "vitest": "^4.0.0"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix"
    ],
    "*.{md,markdown,yml,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": "20.x"
  }
}
